{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hatching-ground/runtime/schemas/runtime-result.schema.json",
  "title": "HatchingGroundRuntimeResult",
  "description": "The portable result returned by a local runtime run. Paths are relative to the selected output directory.",
  "type": "object",
  "required": ["request_id", "session_id", "run_id", "agent_id", "workflow", "runtime_mode", "status", "started_at", "completed_at", "event_stream_path", "run_status_path", "artifact_manifest_path", "artifact_paths", "summary", "warnings"],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "enum": ["full_architecture"] },
    "runtime_mode": { "type": "string", "enum": ["mock"] },
    "status": { "type": "string", "enum": ["completed", "failed"] },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "event_stream_path": { "type": "string", "minLength": 1 },
    "run_status_path": { "type": "string", "minLength": 1 },
    "artifact_manifest_path": { "type": "string", "minLength": 1 },
    "artifact_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "summary": { "type": "string", "minLength": 1 },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
