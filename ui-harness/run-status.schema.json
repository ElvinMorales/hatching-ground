{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hatching-ground/ui-harness/run-status.schema.json",
  "title": "HatchingGroundRunStatus",
  "description": "The user-visible status of one future local harness run.",
  "type": "object",
  "required": ["run_id", "session_id", "workflow", "status", "current_step", "started_at", "updated_at", "completed_at", "progress_percent", "pending_approval_id", "artifact_ids", "error_summary"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["idle", "queued", "running", "waiting_for_approval", "completed", "failed", "cancelled"] },
    "current_step": { "type": ["string", "null"] },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "pending_approval_id": { "type": ["string", "null"] },
    "artifact_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "error_summary": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
