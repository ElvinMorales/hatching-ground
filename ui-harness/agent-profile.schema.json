{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hatching-ground/ui-harness/agent-profile.schema.json",
  "title": "HatchingGroundAgentProfile",
  "description": "A profile displayed by the future local harness for an available agent or adapter-backed role.",
  "type": "object",
  "required": ["agent_id", "display_name", "description", "privacy_level", "capabilities", "supported_workflows", "required_inputs", "artifact_types", "runtime_mode", "tool_permissions", "memory_behavior", "state_behavior"],
  "properties": {
    "agent_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "privacy_level": { "type": "string", "enum": ["public-safe-only", "local-private"] },
    "capabilities": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "supported_workflows": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "required_inputs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "artifact_types": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "runtime_mode": { "type": "string", "enum": ["mock", "local-adapter", "provider-adapter"] },
    "tool_permissions": {
      "type": "object",
      "required": ["allowed", "requires_approval"],
      "properties": {
        "allowed": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "requires_approval": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "memory_behavior": { "type": "string", "description": "Explicit statement of whether and how memory is used; the baseline should be no live memory." },
    "state_behavior": { "type": "string", "description": "Explicit statement of local session-state behavior, kept separate from memory." }
  },
  "additionalProperties": false
}
